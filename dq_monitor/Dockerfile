# Dockerfile — рецепт, по которому Docker собирает контейнер с приложением.
# Каждая команда (FROM, COPY, RUN, CMD) — отдельный шаг сборки.
# Docker кеширует каждый шаг — если он не изменился, при следующей сборке
# Docker возьмёт его из кеша вместо повторной работы. Поэтому порядок шагов
# важен: то, что меняется редко (зависимости), идёт раньше; то, что часто
# (наш код), — позже.

# ────────────────────────────────────────────────────────────────────────
# FROM — выбираем базовый образ. python:3.11-slim — официальный образ
# Python 3.11 на slim-Linux (~50 МБ против ~900 МБ полного python:3.11).
FROM python:3.11-slim

# ────────────────────────────────────────────────────────────────────────
# WORKDIR — внутри контейнера переходим в /app и работаем оттуда.
WORKDIR /app

# ────────────────────────────────────────────────────────────────────────
# Зависимости — копируем ТОЛЬКО requirements.txt и ставим пакеты.
# Это делаем ДО копирования кода, чтобы при изменении кода не пересобирать
# слой с зависимостями (он тяжёлый, ~200 МБ).
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ────────────────────────────────────────────────────────────────────────
# Код приложения — копируем после установки зависимостей.
COPY src/ ./src/
COPY app/ ./app/
COPY .streamlit/ ./.streamlit/
COPY ./api_key.env ./api_key.env

# ────────────────────────────────────────────────────────────────────────
# EXPOSE — Streamlit по умолчанию слушает порт 8501.
# Это просто документация — реально пробрасывать порт надо через -p при запуске.
EXPOSE 8501

# ────────────────────────────────────────────────────────────────────────
# CMD — команда, которая запускается при `docker run`.
#   --server.address=0.0.0.0 — слушать на всех интерфейсах (иначе изнутри
#     контейнера приложение не будет доступно снаружи)
#   --server.headless=true   — не пытаться открыть браузер (его в контейнере нет)
CMD ["streamlit", "run", "app/streamlit_app.py", \
     "--server.address=0.0.0.0", \
     "--server.port=8501", \
     "--server.headless=true"]
